modules = ["swift-5.8", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "vnc"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "flutter run -d linux 2>&1 || flutter run -d web-server --web-port 5000 --web-hostname 0.0.0.0 2>&1"

[[ports]]
localPort = 5000
externalPort = 80
